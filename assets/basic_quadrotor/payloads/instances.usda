    def Xform "BottomFrame" (
        prepend references = @./geometries.usd@</Geometries/BottomFrame>
    )
    {
        over "BottomFrame" (
            apiSchemas = ["MaterialBindingAPI"]
        )
        {
            custom rel material:binding
            prepend rel material:binding = </Instances/BottomFrame/VisualMaterials/tn__Fibre_de_carbone__Tresse_vZ0jX4>
        }

        def Scope "VisualMaterials"
        {
            def Material "tn__Fibre_de_carbone__Tresse_vZ0jX4" (
                prepend references = @./visual_materials.usda@</VisualMaterials/tn__Fibre_de_carbone__Tresse_vZ0jX4>
            )
            {
            }
        }
    }

    def Xform "BottomFrame_1" (
        prepend references = @./geometries.usd@</Geometries/BottomFrame>
    )
    {
        over "BottomFrame" (
            apiSchemas = ["PhysicsCollisionAPI", "PhysicsMeshCollisionAPI"]
        )
        {
            # Bottom frame is a flat carbon-fibre plate. PhysX's GPU
            # convex-hull cooker rejects it ("oblong shape") and falls
            # back to CPU collision, which kills GPU broadphase
            # performance. boundingCube is exact for a flat plate and
            # always GPU-compatible.
            token physics:approximation = "boundingCube"
        }
    }

